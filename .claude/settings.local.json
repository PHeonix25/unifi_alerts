{
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(gh run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(py -m pytest tests/ -v)",
      "Bash(.venv/Scripts/pytest tests/ -v)",
      "Bash(.venv/Scripts/ruff check:*)",
      "Bash(.venv/Scripts/ruff format:*)",
      "Bash(.venv/Scripts/mypy custom_components/ --ignore-missing-imports)",
      "PowerShell(py:*)",
      "PowerShell(.venv\\\\Scripts\\\\pytest tests/ -v 2>&1)",
      "PowerShell(.venv\\\\Scripts\\\\ruff format custom_components/ 2>&1)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:ui.com)",
      "WebFetch(domain:help.ui.com)",
      "WebSearch"
    ]
  },
  "defaultShell": "powershell"
}
